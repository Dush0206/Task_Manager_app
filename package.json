{
  "name": "task-manager-app",
  "version": "1.0.0",
  "description": "A full-stack task management web application with user authentication, CRUD operations, and real-time updates",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"cd client && npm start\"",
    "client": "cd client && npm start",
    "server": "nodemon server/index.js",
    "install-all": "npm install && cd client && npm install"
  },
  "keywords": ["task-management", "react", "nodejs", "express", "mongodb"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
